rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Obra structure validation
    function isValidObra(data) {
      return data.keys().hasAll(['cliente', 'dataContrato']) &&
             data.cliente is string && data.cliente.size() <= 200 &&
             data.dataContrato is string &&
             (data.get('funcionario', '') is string) &&
             (data.get('pagamento', '') is string) &&
             (data.get('equipe', '') is string) &&
             (data.get('local', '') is string) &&
             (data.get('obs', '') is string) &&
             (data.get('qtPlaca', 0) is number);
    }

    match /obras/{obraId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && 
                    isValidObra(incoming()) && 
                    incoming().createdBy == request.auth.uid &&
                    incoming().createdAt == request.time;
      allow update: if isSignedIn() && 
                    isValidObra(incoming()) && 
                    incoming().updatedAt == request.time;
      allow delete: if isSignedIn() && 
                    (existing().createdBy == request.auth.uid || 
                     request.auth.token.email == 'jouguemoto@gmail.com');
    }
  }
}
